---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <div class="min-h-screen bg-gradient-to-br from-cream via-forest-light to-cream dark:from-forest-dark dark:via-forest-green/10 dark:to-forest-dark">
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-10 left-10 w-72 h-72 bg-emerald/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-forest-green/10 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <!-- Dashboard Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold text-forest-dark dark:text-cream mb-2">Dashboard</h1>
        <p class="text-sage">Welcome back! Here's your productivity overview.</p>
      </div>

      <!-- Stats Grid -->
      <div class="grid md:grid-cols-4 gap-4 mb-12">
        <div class="p-6 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
          <div class="text-sm text-sage mb-2">Total Trees</div>
          <div class="text-3xl font-bold text-emerald">12</div>
          <div class="text-xs text-sage mt-2">+2 this week</div>
        </div>
        <div class="p-6 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
          <div class="text-sm text-sage mb-2">Focus Hours</div>
          <div class="text-3xl font-bold text-forest-green">18.5</div>
          <div class="text-xs text-sage mt-2">This week</div>
        </div>
        <div class="p-6 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
          <div class="text-sm text-sage mb-2">Tasks Completed</div>
          <div class="text-3xl font-bold text-forest-dark dark:text-cream">48</div>
          <div class="text-xs text-sage mt-2">This month</div>
        </div>
        <div class="p-6 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
          <div class="text-sm text-sage mb-2">Current Streak</div>
          <div class="text-3xl font-bold text-amber-600">7</div>
          <div class="text-xs text-sage mt-2">Days</div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="grid lg:grid-cols-3 gap-6">
        <!-- Forest Visualization -->
        <div class="lg:col-span-2 p-8 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
          <h2 class="text-2xl font-bold text-forest-dark dark:text-cream mb-6">Your Forest</h2>
          <div class="h-80 flex items-center justify-center text-6xl">
            🌲🌲🌳🌲🌴
          </div>
          <p class="text-center text-sage mt-4">Level 5 Forest Master - Keep growing!</p>
        </div>

        <!-- Quick Actions -->
        <div class="p-8 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
          <h2 class="text-2xl font-bold text-forest-dark dark:text-cream mb-6">Quick Access</h2>
          <div class="space-y-3">
            <a href="/tasks" class="block p-3 rounded-lg bg-emerald/10 hover:bg-emerald/20 transition text-forest-dark dark:text-cream font-semibold">
              📋 View Tasks
            </a>
            <a href="/focus" class="block p-3 rounded-lg bg-emerald/10 hover:bg-emerald/20 transition text-forest-dark dark:text-cream font-semibold">
              ⏱️ Start Focus
            </a>
            <a href="/forest" class="block p-3 rounded-lg bg-emerald/10 hover:bg-emerald/20 transition text-forest-dark dark:text-cream font-semibold">
              🌍 View Forest
            </a>
            <a href="/stats" class="block p-3 rounded-lg bg-emerald/10 hover:bg-emerald/20 transition text-forest-dark dark:text-cream font-semibold">
              📊 Statistics
            </a>
          </div>
        </div>
      </div>

      <!-- Recent Activities -->
      <div class="mt-12 p-8 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
        <h2 class="text-2xl font-bold text-forest-dark dark:text-cream mb-6">Recent Activity</h2>
        <div class="space-y-3">
          <div class="flex items-center gap-4 p-3 rounded-lg bg-emerald/5">
            <span class="text-2xl">🌱</span>
            <div>
              <p class="font-semibold text-forest-dark dark:text-cream">Completed "Finish Project Report"</p>
              <p class="text-sm text-sage">2 hours ago</p>
            </div>
          </div>
          <div class="flex items-center gap-4 p-3 rounded-lg bg-emerald/5">
            <span class="text-2xl">🎯</span>
            <div>
              <p class="font-semibold text-forest-dark dark:text-cream">Completed 4 focus sessions</p>
              <p class="text-sm text-sage">Today</p>
            </div>
          </div>
          <div class="flex items-center gap-4 p-3 rounded-lg bg-emerald/5">
            <span class="text-2xl">🏆</span>
            <div>
              <p class="font-semibold text-forest-dark dark:text-cream">Earned "7-Day Streak" achievement</p>
              <p class="text-sm text-sage">Yesterday</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
