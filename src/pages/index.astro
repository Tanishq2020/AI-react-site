---
import MainLayout from '../layouts/MainLayout.astro';
import { motion } from 'framer-motion';
---

<MainLayout>
  <div class="min-h-screen bg-gradient-to-br from-cream via-forest-light to-cream dark:from-forest-dark dark:via-forest-green/10 dark:to-forest-dark">
    <!-- Animated background elements -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-10 left-10 w-72 h-72 bg-emerald/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-forest-green/10 rounded-full blur-3xl"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <!-- Hero Section -->
      <div class="text-center mb-20">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-forest-dark dark:text-cream mb-6">
          Welcome to <span class="bg-gradient-to-r from-emerald to-forest-green bg-clip-text text-transparent">Study Forest</span>
        </h1>
        <p class="text-xl text-sage mb-8 max-w-2xl mx-auto">
          Grow a virtual forest by completing tasks and focus sessions. Watch your productivity bloom into a thriving ecosystem.
        </p>
        <a href="/dashboard" class="inline-block px-8 py-4 bg-gradient-to-br from-emerald to-forest-green text-cream rounded-xl font-semibold hover:shadow-xl transition transform hover:scale-105">
          Start Growing 🌱
        </a>
      </div>

      <!-- Features Grid -->
      <div class="grid md:grid-cols-3 gap-6 mt-20">
        <div class="p-6 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20 hover:border-emerald/50 transition">
          <div class="text-4xl mb-4">📋</div>
          <h3 class="text-xl font-bold text-forest-dark dark:text-cream mb-2">Task Manager</h3>
          <p class="text-sage">Create and organize your daily tasks with priority levels and due dates.</p>
        </div>
        <div class="p-6 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20 hover:border-emerald/50 transition">
          <div class="text-4xl mb-4">⏱️</div>
          <h3 class="text-xl font-bold text-forest-dark dark:text-cream mb-2">Focus Timer</h3>
          <p class="text-sage">Use the Pomodoro technique to maintain focus and track your productivity.</p>
        </div>
        <div class="p-6 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20 hover:border-emerald/50 transition">
          <div class="text-4xl mb-4">🌲</div>
          <h3 class="text-xl font-bold text-forest-dark dark:text-cream mb-2">Virtual Forest</h3>
          <p class="text-sage">Watch your forest grow with each completed task and focus session.</p>
        </div>
      </div>

      <!-- Statistics Preview -->
      <div class="grid md:grid-cols-3 gap-6 mt-16">
        <div class="text-center p-8 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
          <div class="text-5xl font-bold text-emerald mb-2">🌍</div>
          <p class="text-3xl font-bold text-forest-dark dark:text-cream">1000+</p>
          <p class="text-sage">Forests Grown</p>
        </div>
        <div class="text-center p-8 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
          <div class="text-5xl font-bold text-emerald mb-2">⏳</div>
          <p class="text-3xl font-bold text-forest-dark dark:text-cream">50K+</p>
          <p class="text-sage">Focus Hours</p>
        </div>
        <div class="text-center p-8 rounded-2xl backdrop-blur-sm bg-white/50 dark:bg-forest-dark/50 border-2 border-emerald/20">
          <div class="text-5xl font-bold text-emerald mb-2">✅</div>
          <p class="text-3xl font-bold text-forest-dark dark:text-cream">100K+</p>
          <p class="text-sage">Tasks Completed</p>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>
